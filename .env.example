APP_ENV=development
APP_DEBUG=true
APP_NAME=Bifrost Arrangør
APP_BASE_URL=http://arrangor.jaktfeltcup.local

BACKEND_URL=http://api.bifrost.local
PUBLIC_REGISTER_URL=http://jaktfeltcup.local/auth/register
ARRANGOR_PORTAL_URL=http://arrangor.jaktfeltcup.local

# Valgfritt — cup-brand fra public-ui JSON (farger/logo). Standard: sibling ../bifrost-public-ui
# PUBLIC_UI_PATH=C:/xampp/htdocs/bifrost/bifrost-public-ui
# PUBLIC_SITE_URL=http://jaktfeltcup.local

# Valgfritt — V3 er på som standard. Events API utledes fra BACKEND_URL.
# I lokal dev brukes intern dispatch (unngår XAMPP HTTP-timeout); sett false for ren HTTP:
# EVENTS_USE_INTERNAL_DISPATCH=false
# EVENTS_USE_LOOPBACK=false
# ADMIN_CORE_PATH=../bifrost-admin-core
# ORGANIZER_PORTAL_V3_ENABLED=false
# EVENTS_URL=http://admin.bifrost.local
# DB_DSN=mysql:host=127.0.0.1;dbname=bifrost_admin_core;charset=utf8mb4
# DB_USER=root
# DB_PASS=
# PORTAL_V3_AUTH_BYPASS=true

# Demo-bruker for V3-smoke (seed 004_demo_portal_org_admin.sql i modules/events):
# E-post: skytecuper-admin@demo.bifrost.local  Passord: Demo123!

# Test (sky) – se .env.test.example:
# APP_BASE_URL=https://test.arrangor.jaktfeltcup.no
# BACKEND_URL=https://test.api.bifrostevents.no
# PUBLIC_REGISTER_URL=https://test.jaktfeltcup.no/auth/register
# ARRANGOR_PORTAL_URL=https://test.arrangor.jaktfeltcup.no

# Prod:
# APP_ENV=production
# APP_DEBUG=false
# APP_BASE_URL=https://arrangor.jaktfeltcup.no
# BACKEND_URL=https://api.bifrostevents.no
# PUBLIC_REGISTER_URL=https://jaktfeltcup.no/auth/register
# ARRANGOR_PORTAL_URL=https://arrangor.jaktfeltcup.no
